# Versões validadas para o Dockerfile da esteira
# Atualizado em: 2026-07-22

# Imagem base
# Digest fixado do manifesto amd64 (docker pull python:3.12-slim em 2026-07-22)
BASE_IMAGE=python:3.12-slim
BASE_IMAGE_DIGEST=sha256:57cd7c3a7a273101a6485ba99423ee568157882804b1124b4dd04266317710de

# GitHub CLI — versão do pacote APT (sem 'v')
# Fonte: https://api.github.com/repos/cli/cli/releases/latest → tag_name v2.96.0
# Instalado via tarball release (não via APT), portanto sem sufixo de distro
GH_VERSION=2.96.0

# PyYAML — versão pip
# Fonte: pip3 index versions pyyaml → versão estável mais recente
PYYAML_VERSION=6.0.3

# kiro-cli
# Fonte: BUILD-INFO extraído de kirocli-x86_64-linux.zip (build 2026-07-21)
# Binário glibc (x86_64-unknown-linux-gnu) — validado em python:3.12-slim ✓
KIRO_CLI_VERSION=2.13.1
KIRO_CLI_SHA256=49d712558cc930d3570387ce468887ca0b510ba8b5f08e2f3c7a7a55d44e677f
KIRO_CLI_URL=https://desktop-release.q.us-east-1.amazonaws.com/latest/kirocli-x86_64-linux.zip

# Pacotes APT (dentro de python:3.12-slim / Debian 13)
# Fonte: apt-cache show <pkg> executado dentro do container python:3.12-slim em 2026-07-22
GIT_APT_VERSION=1:2.47.3-0+deb13u1
OPENSSH_CLIENT_APT_VERSION=1:10.0p1-7+deb13u4
