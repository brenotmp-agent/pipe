# ─── Variáveis de ambiente — Esteira Agêntica ────────────────────────────────
#
# Copie este arquivo para .env e preencha os valores antes de executar:
#   cp .env.example .env
#
# O docker-compose.yml lê automaticamente o .env na mesma pasta.

# Token de acesso ao GitHub com permissões de leitura/escrita em issues e projects.
# Gere em: https://github.com/settings/tokens
# Escopos necessários: repo, project
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Caminho absoluto da chave SSH privada no host (usada para operações git via SSH).
# Deve ser a mesma chave registrada no GitHub.
# Padrão: ~/.ssh/id_ed25519
SSH_KEY_FILE=~/.ssh/id_ed25519

# Diretório de configuração do gh CLI no host.
# Gerado automaticamente por `gh auth login`.
# Padrão: ~/.config/gh
GH_CONFIG_DIR=~/.config/gh

# ─── Estado de runtime (US-04) ───────────────────────────────────────────────
# Caminhos no HOST para os diretórios de estado da esteira.
# Cada variável tem um default (o diretório ao lado do compose) — as linhas
# abaixo são opcionais: comente para usar o default ou ajuste para outro caminho.

# .pipe/ — snapshots de boards, sessões de agente, throttle.
# Perde: continuidade de raciocínio dos agentes + re-sync completo. [persistir]
PIPE_STATE_DIR=./.pipe

# repo/ — clones git dos repositórios configurados.
# Perde: re-clone de todos os repositórios a cada subida. [persistir]
PIPE_REPO_DIR=./repo

# logs/ — histórico de execução (JSON diário + MD por execução de agente).
# Perde: só o histórico; operação segue normal. [conveniência]
PIPE_LOGS_DIR=./logs
