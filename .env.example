# ─── Variáveis de ambiente — Esteira Agêntica ────────────────────────────────
#
# Copie este arquivo para .env e preencha os valores antes de executar:
#   cp .env.example .env
#
# O docker-compose.yml lê automaticamente o .env na mesma pasta.

# Token de acesso ao GitHub com permissões de leitura/escrita em issues e projects.
# Gere em: https://github.com/settings/tokens
# Escopos necessários: repo, project
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API key do kiro-cli para operação em modo headless (sem login interativo).
# Necessária para planos Pro/Pro+/Pro Max/Power.
# Gere em: https://app.kiro.dev → API Keys
KIRO_API_KEY=kiro_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Caminho absoluto da chave SSH privada no host (usada para operações git via SSH).
# Deve ser a mesma chave registrada no GitHub.
# Padrão: ~/.ssh/id_ed25519
SSH_KEY_FILE=~/.ssh/id_ed25519

# Diretório de configuração do gh CLI no host.
# Gerado automaticamente por `gh auth login`.
# Padrão: ~/.config/gh
GH_CONFIG_DIR=~/.config/gh
