# ⚠️ PROTÓTIPO DE UX — NÃO É O ARTEFATO FINAL DE DEPLOY
#
# Exemplo de .env para parametrizar os caminhos de estado SEM editar YAML.
# Fluxo pretendido: copiar para `.env`, ajustar se necessário, `docker compose up`.
#
# Cada variável aponta um diretório do HOST que será montado no container.
# A frase é "o que você perde se este diretório não persistir".

# .pipe/ — snapshots, sessões de agente, throttle.
# Perde: continuidade de raciocínio dos agentes + re-sync completo. [persistir]
PIPE_STATE_DIR=./.pipe

# repo/ — clones git dos repositórios configurados.
# Perde: re-clone de todos os repositórios a cada subida. [persistir]
PIPE_REPO_DIR=./repo

# logs/ — histórico de execução (JSON diário + MD por execução).
# Perde: só o histórico; operação segue normal. [conveniência]
PIPE_LOGS_DIR=./logs

# Config/segredos (US-02/US-03), não é estado de runtime:
# PIPE_CONFIG_FILE=./pipe.yml
# PIPE_CONTEXTS_DIR=./contexts
