# .env.prototipo — variáveis de estado e credenciais (US-04 D-05)
#
# Este arquivo é um MODELO — copiar para .env e preencher.
# NUNCA versionar o .env (já está no .gitignore).
#
# Ver: doc/stories/rodar-no-docker/arquitetura.md §6 (tabela de variáveis)

# ─── Segredos (obrigatório) ───────────────────────────────────────────────────

# Token de acesso ao GitHub (escopos: repo, project)
# Gerar em: https://github.com/settings/tokens
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Caminhos de credenciais (opcional — tem default) ─────────────────────────

# Chave SSH privada no HOST (deve estar cadastrada no GitHub)
# Default: ~/.ssh/id_ed25519
SSH_KEY_FILE=~/.ssh/id_ed25519

# Diretório de configuração do gh CLI no HOST
# Gerado por `gh auth login` — não alterar sem necessidade
# Default: ~/.config/gh
GH_CONFIG_DIR=~/.config/gh

# ─── Estado de runtime (US-04 — opcional, tem default) ────────────────────────
#
# Caminhos NO HOST para os diretórios de estado da esteira.
# Com defaults inline no compose, estas linhas são opcionais:
# comente para usar os defaults (diretórios ao lado do compose).
#
# Para modo EFÊMERO (sem persistência), usar compose.ephemeral.yml
# em vez de remover ou esvaziar estas variáveis.

# .pipe/ — snapshots de boards, sessões de agente, throttle.
# Perde: continuidade de raciocínio dos agentes + re-sync completo. [persistir]
PIPE_STATE_DIR=./.pipe

# repo/ — clones git dos repositórios configurados.
# Perde: re-clone de todos os repositórios a cada subida. [persistir]
PIPE_REPO_DIR=./repo

# logs/ — histórico de execução (JSON diário + MD por execução de agente).
# Perde: só o histórico; operação segue normal. [conveniência]
PIPE_LOGS_DIR=./logs
